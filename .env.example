# Copy to .env (gitignored) and fill in. Leave blank what you do not use.
# NOTE: the MCP server reads these from your shell/OS environment, not from this
# file directly — `.env` is for your own loading convenience. Never commit secrets.

# ComfyUI instance the MCP / agent layer drives.
# ComfyUI Desktop defaults to port 8000; a manual `python main.py` install uses 8188.
COMFYUI_URL=http://127.0.0.1:8000

# Optional: CivitAI token for GATED model downloads via the MCP's download_model tool.
# Read by comfyui-mcp as CIVITAI_API_TOKEN. Keep the real value here (gitignored) and
# never inside the tracked .mcp.json.
CIVITAI_API_TOKEN=

# Optional API keys for API-backed nodes (e.g. Gemini LLM node)
GEMINI_API_KEY=

# ---------------------------------------------------------------------------
# Agent LLM layer (Qwen3 via Ollama, recommended). OpenAI-compatible /v1, so any provider works.
# The agent layer uses TWO kinds of model:
#   * a VISION judge (scores renders against the rubric)      — Qwen3-VL  (run the loop with --backend api)
#   * TEXT roles: codegen (FreeCAD scripts) + prompt rewriter — Qwen3.6
# Recommended local setup — install Ollama, then:
#   ollama pull qwen3-vl:8b   &&   ollama pull qwen3.6-27b
# and export the vars below (or load this .env). The agent reads them from your shell/OS env.
CHIMERA_LLM_BASE_URL=http://localhost:11434/v1
CHIMERA_LLM_API_KEY=
# Shared fallback model (if you run ONE model for everything). Per-role below is preferred.
CHIMERA_LLM_MODEL=

# Per-role (specific-wins over the shared vars above). Each is a pure swap: change the value +
# `ollama pull <tag>` — no code change. Base URL falls back to CHIMERA_LLM_BASE_URL above.
CHIMERA_JUDGE_MODEL=qwen3-vl:8b      # vision judge. Upgrades: qwen3-vl:32b (sharpest) · qwen3-vl:30b-a3b (MoE balance)
CHIMERA_CODEGEN_MODEL=qwen3.6-27b    # FreeCAD codegen (model strength matters most here)
CHIMERA_REWRITER_MODEL=qwen3.6-27b   # prompt rewriter (a smaller/faster text model is fine)

# Lesser GPU? Keep the light 8B judge local and point JUST codegen at a smaller model OR the cloud:
#   CHIMERA_CODEGEN_BASE_URL=https://openrouter.ai/api/v1
#   CHIMERA_CODEGEN_MODEL=qwen/qwen3-coder          # or any strong code model
#   CHIMERA_CODEGEN_API_KEY=<key>
# Or run the WHOLE agent layer on the cloud (no local GPU) — set CHIMERA_LLM_BASE_URL to a cloud /v1:
#   Gemini    https://generativelanguage.googleapis.com/v1beta/openai  + gemini-2.5-pro
#   OpenAI    https://api.openai.com/v1                                 + gpt-4o
#   Anthropic https://api.anthropic.com/v1                             + claude-opus-4-8
