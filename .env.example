# Copy to .env (gitignored) and fill in. Leave blank what you do not use.
# NOTE: the MCP server reads these from your shell/OS environment, not from this
# file directly — `.env` is for your own loading convenience. Never commit secrets.

# ComfyUI instance the MCP / agent layer drives.
# ComfyUI Desktop defaults to port 8000; a manual `python main.py` install uses 8188.
COMFYUI_URL=http://127.0.0.1:8000

# Optional: CivitAI token for GATED model downloads via the MCP's download_model tool.
# Read by comfyui-mcp as CIVITAI_API_TOKEN. Keep the real value here (gitignored) and
# never inside the tracked .mcp.json.
CIVITAI_API_TOKEN=

# Optional API keys for API-backed nodes (e.g. Gemini LLM node)
GEMINI_API_KEY=

# Provider-agnostic LLM backend for the agent loop's `--backend api` (AI judge) and
# `--pipeline cad` (autonomous generative CAD). OpenAI-compatible /v1/chat/completions, so any
# provider works — set the base URL + model + key for ONE (see modules/agent/self-correction.md):
#   Gemini:    https://generativelanguage.googleapis.com/v1beta/openai  + gemini-2.5-pro
#   OpenAI:    https://api.openai.com/v1                                 + gpt-4o
#   Anthropic: https://api.anthropic.com/v1                             + claude-opus-4-8
#   Local:     http://localhost:11434/v1 (Ollama)                       + a local model (no key)
CHIMERA_LLM_BASE_URL=
CHIMERA_LLM_MODEL=
CHIMERA_LLM_API_KEY=

# --- Per-role overrides (AUTONOMOUS auto_generate.py runs ONLY — ignored when an AI agent drives
#     interactively in your IDE). Each role falls back to the shared CHIMERA_LLM_* above if unset. ---
# Codegen (FreeCAD scripts, --pipeline cad) — a strong CODE model:
#   CHIMERA_CODEGEN_BASE_URL=https://openrouter.ai/api/v1
#   CHIMERA_CODEGEN_MODEL=qwen/qwen2.5-coder-32b-instruct
#   CHIMERA_CODEGEN_API_KEY=<key>
# Judge (--backend api) — a VISION model:
#   CHIMERA_JUDGE_BASE_URL=http://localhost:11434/v1
#   CHIMERA_JUDGE_MODEL=qwen2.5vl:7b
# Rewriter (--rewrite-prompts) — a fast TEXT model:
#   CHIMERA_REWRITER_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
#   CHIMERA_REWRITER_MODEL=gemini-2.5-flash
#   CHIMERA_REWRITER_API_KEY=<key>
